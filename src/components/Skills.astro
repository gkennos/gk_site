---
import { SITE_DATA, SKILL_GROUPS, TECH_STACK } from '../data/site';
import { withBase } from '../utils/paths';
---

<section id="skills" class="border-b border-slate-950 bg-white">
	<div class="px-4 py-20 sm:px-6 md:px-8 md:py-24">
		<div class="space-y-6">
			<div class="max-w-4xl space-y-3">
				<p class="text-xs font-semibold tracking-[0.28em] text-slate-500 uppercase"></p>
				<p
					class="max-w-[46rem] text-[0.98rem] leading-7 text-slate-600 md:text-[1.05rem] md:leading-8"
				>
					This work supports the mission of the
					<a
						href={SITE_DATA.employerLink}
						target="_blank"
						rel="noreferrer"
						class="font-medium text-slate-900 underline decoration-slate-300 underline-offset-4 transition hover:decoration-slate-950"
					>
						{SITE_DATA.employerName}
					</a>
					, with a focus on evidence generation for improved care and a reduction in unwarranted variation
					from cancer diagnosis and treatment through survivorship and supportive care.
				</p>
			</div>
			<div class="grid gap-5 xl:grid-cols-2">
				{
					SKILL_GROUPS.map((group) => (
						<section class="rounded-[1.75rem] border border-slate-950 bg-[#fcfbf8] p-6">
							<h3 class="font-archivo text-2xl font-black tracking-[-0.02em] text-slate-950 uppercase">
								{group.title}
							</h3>
							<div class="mt-5 flex flex-wrap gap-2.5">
								{group.items.map((item) => (
									<span class="inline-flex rounded-full border border-slate-300 bg-white px-3 py-2 text-xs font-semibold tracking-[0.16em] text-slate-700 uppercase">
										{item}
									</span>
								))}
							</div>
						</section>
					))
				}
			</div>

			<div class="pt-2">
				<div class="mt-6 flex flex-wrap gap-x-6 gap-y-4">
					{
						TECH_STACK.map((skill) => (
							<div class="inline-flex items-center gap-3">
								{skill.iconPath ? (
									<img
										class={`object-contain ${skill.iconClass ?? 'h-7 w-7'}`}
										src={withBase(skill.iconPath)}
										alt=""
										aria-hidden="true"
									/>
								) : (
									<span
										class="inline-flex items-center justify-center text-[1.75rem]"
										style={`color: ${skill.color}; font-size: ${skill.iconSize ?? '1.75rem'};`}
									>
										<i class={skill.icon} aria-hidden="true" />
									</span>
								)}
								<span class="text-xs font-semibold tracking-[0.16em] text-slate-800 uppercase">
									{skill.label}
								</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>
