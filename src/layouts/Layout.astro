---
import '../styles/global.css';
import Header from '../components/Header.astro';
import { withBase } from '../utils/paths';

interface Props {
	title: string;
	siteName: string;
	siteDescription: string;
}

const { title, siteName, siteDescription } = Astro.props;
const faviconHref = withBase('/assets/svg/icons/cava_mark.svg');
const sitemapHref = withBase('/sitemap-index.xml');
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={siteDescription} />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={siteDescription} />
		<link rel="sitemap" href={sitemapHref} />
		<link
			rel="stylesheet"
			href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
		/>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Archivo:wght@500..900&family=Manrope:wght@200..800&display=swap"
		/>
		<style is:global>
			.font-manrope {
				font-family: 'Manrope', sans-serif;
			}

			.font-archivo {
				font-family: 'Archivo', sans-serif;
			}
		</style>
	</head>
	<body class="font-manrope bg-white text-slate-950">
		<div class="min-h-dvh bg-white px-0 sm:px-4">
			<div
				class="mx-auto flex min-h-dvh w-full max-w-[86rem] flex-col border-x border-slate-950 bg-white"
			>
				<Header />
				<main class="flex-1">
					<slot />
				</main>
				<footer class="border-t border-slate-950 bg-white">
					<div class="flex justify-end px-4 py-6 sm:px-6 md:px-8">
						<a
							href={withBase('/contact')}
							class="inline-flex items-center gap-3 text-xs font-bold tracking-[0.28em] text-slate-700 uppercase transition hover:text-slate-950 md:text-sm"
						>
							<span>Contact</span>
							<span aria-hidden="true" class="text-xl leading-none font-black text-[#d97706]"
								>→</span
							>
						</a>
					</div>
				</footer>
			</div>
		</div>
	</body>
</html>
