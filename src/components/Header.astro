---
import { SITE_DATA, SOCIAL_LINKS } from '../data/site';
import { withBase } from '../utils/paths';
---

<header class="sticky top-0 z-20 border-b border-slate-950 bg-white/90 backdrop-blur">
	<div class="flex h-20 w-full items-center justify-between gap-4 px-4 sm:px-6 md:px-8">
		<a
			href={withBase('/')}
			class="font-archivo text-sm font-black tracking-[0.28em] text-slate-950 uppercase md:text-base"
		>
			{SITE_DATA.pageHeader}
		</a>

		<div class="hidden items-center gap-3 md:flex">
			{
				SOCIAL_LINKS.map((social) => {
					const href = social.href.startsWith('/') ? withBase(social.href) : social.href;
					const isInternal = social.href.startsWith('/');
					const isMail = social.href.startsWith('mailto:');
					const iconStyle =
						'color' in social && social.color ? `color: ${social.color};` : undefined;
					const imageStyle = 'imageStyle' in social ? String(social.imageStyle) : undefined;

					return (
						<a
							href={href}
							target={isInternal || isMail ? undefined : '_blank'}
							rel={isInternal || isMail ? undefined : 'noreferrer'}
							aria-label={social.label}
							class="inline-flex size-10 items-center justify-center text-slate-700"
						>
							<span class="inline-flex items-center justify-center drop-shadow-[0_1.5px_1.5px_rgba(15,23,42,0.22)]">
								{'iconClass' in social ? (
									<i
										class={`${social.iconClass} text-[1.5rem]`}
										style={iconStyle}
										aria-hidden="true"
									/>
								) : (
									<img
										src={withBase(social.icon!)}
										alt={social.label}
										class={'imageClass' in social ? social.imageClass : 'size-6'}
										style={imageStyle}
									/>
								)}
							</span>
						</a>
					);
				})
			}
		</div>
	</div>
</header>
