---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Writing | Georgie Kennedy, PhD"
	siteName="Georgie Kennedy, PhD"
	siteDescription="Writing and notes."
>
	<section class="border-b border-slate-950 bg-white">
		<div class="px-4 py-20 sm:px-6 md:px-8 md:py-24">
			<div class="max-w-4xl space-y-6">
				<p class="text-xs font-semibold tracking-[0.28em] text-slate-500 uppercase">Writing</p>
				<h1
					class="font-archivo text-5xl leading-[0.95] font-black tracking-[-0.04em] uppercase md:text-7xl"
				>
					Notes and Writing
				</h1>
				<p class="max-w-2xl text-base leading-8 text-slate-700 md:text-lg md:leading-9">
					This page is ready for essays, notes, and project-adjacent writing when you are.
				</p>
			</div>
		</div>
	</section>
</Layout>
